<% if @feed_items.any? %>
  <!-- Danh sách bài đăng trên bảng tin -->
  <ol class="divide-y divide-gray-100">
    <%= render @feed_items %>
  </ol>
  <!-- Thanh phân trang Pagy siêu nhẹ -->
  <div class="mt-6 flex justify-center">
    <%== pagy_nav(@pagy) %>
  </div>
<% else %>
  <div class="text-center py-12 text-gray-400 text-sm">
    Your feed is empty. Start posting something!
  </div>
<% end %>