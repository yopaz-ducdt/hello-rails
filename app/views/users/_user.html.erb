<li class="py-4 flex items-center justify-between hover:bg-gray-50 px-4 rounded-xl transition">
  <div class="flex items-center space-x-4">
    <%= gravatar_for user %>
    <div>
      <%= link_to user.name, user, class: "text-base font-semibold text-gray-900 hover:text-blue-600 transition" %>
      <p class="text-xs text-gray-500"><%= user.email %></p>
    </div>
  </div>
  <!-- Nếu người đang đăng nhập là Admin và dòng này không phải của chính mình -->
  <% if current_user.admin? && !current_user?(user) %>
    <%= link_to "Delete", user, data: { "turbo-method": :delete,
                                        "turbo-confirm": "Are you sure you want to delete this user?" },
                                class: "text-xs font-semibold text-red-600 hover:text-red-800 hover:underline bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-lg transition cursor-pointer" %>
  <% end %>
</li>