<% provide(:title, "All users") %>
<div class="max-w-2xl mx-auto mt-10 bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
  <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight mb-6 text-center">
    All users
  </h1>
  <!-- Thanh phân trang phía trên -->
  <div class="flex justify-center mb-4 text-sm font-medium">
    <%== pagy_nav(@pagy) if @pagy && @pagy.pages > 1 %>
  </div>
  <!-- Danh sách thành viên -->
  <ul class="divide-y divide-gray-100">
    <%= render @users %>
  </ul>
  <!-- Thanh phân trang phía dưới -->
  <div class="flex justify-center mt-6 text-sm font-medium">
    <%== pagy_nav(@pagy) if @pagy && @pagy.pages > 1 %>
  </div>
</div>