<% provide(:title, @title) %>
<div class="max-w-6xl mx-auto mt-8 px-4 grid grid-cols-1 md:grid-cols-3 gap-8">
  <!-- CỘT TRÁI: THÔNG TIN TÓM TẮT & AVATAR MINI -->
  <div class="space-y-6">
    <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm space-y-4">
      <div class="flex items-center space-x-3">
        <%= gravatar_for @user %>
        <div>
          <h2 class="font-bold text-gray-900 leading-tight"><%= @user.name %></h2>
          <%= link_to "view my profile", @user, class: "text-xs text-blue-600 hover:underline" %>
          <div class="text-xs text-gray-400 mt-0.5">
            <%= pluralize(@user.microposts.count, "micropost") %>
          </div>
        </div>
      </div>
      <!-- Bộ số liệu thống kê tổng hợp -->
      <%= render 'shared/stats' %>
    </div>
  </div>
  <!-- CỘT PHẢI: CHI TIẾT DANH SÁCH NGƯỜI DÙNG -->
  <div class="md:col-span-2 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
    <h3 class="text-xl font-bold text-gray-900 mb-6 border-b border-gray-50 pb-4">
      <%= @title %>
    </h3>
    <% if @users.any? %>
      <!-- Duyệt qua mảng users để vẽ danh sách (Rails tự động map với partial _user.html.erb) -->
      <ul class="divide-y divide-gray-100">
        <%= render @users %>
      </ul>
      <!-- Thanh điều hướng phân trang Pagy -->
      <div class="mt-6 flex justify-center">
        <%== pagy_nav(@pagy) %>
      </div>
    <% else %>
      <div class="text-center py-12 text-gray-400 text-sm">
        No users to display in this list.
      </div>
    <% end %>
  </div>
</div>