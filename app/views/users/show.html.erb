<% provide(:title, @user.name) %>
<div class="grid grid-cols-1 md:grid-cols-4 gap-8 max-w-5xl mx-auto mt-6">
  <!-- Cột Sidebar bên trái (Chiếm 1 phần) -->
  <aside class="md:col-span-1 bg-white p-6 rounded-xl border border-gray-100 shadow-sm flex flex-col items-center text-center h-fit">
    <section class="user_info">
      <div class="mb-3 flex justify-center">
        <!-- Gọi hàm helper Gravatar vừa viết ở bước trên -->
        <%= gravatar_for @user %>
      </div>
      <h1 class="text-xl font-bold text-gray-900 leading-tight">
        <%= @user.name %>
      </h1>
    </section>
  </aside>
  <!-- Cột nội dung bên phải (Chiếm 3 phần - Tạm thời để trống theo đúng tiến độ sách) -->
  <div class="md:col-span-3">
    <!-- Sau này ở các chương sau chúng ta sẽ hiển thị danh sách bài đăng ở đây -->
  </div>
</div>