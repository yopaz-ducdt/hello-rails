<% provide(:title, "Reset password") %>
<div class="max-w-md mx-auto mt-16 bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
  <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight mb-6 text-center">
    Reset password
  </h1>
  <%= form_with(model: @user, url: password_reset_path(params[:id]), local: true) do |f| %>
    <!-- Hiển thị bảng báo lỗi nếu có -->
    <%= render 'shared/error_messages', object: f.object %>
    <!-- Truyền ngầm Email lên kèm theo form bằng thẻ ẩn hiddien_field -->
    <%= hidden_field_tag :email, @user.email %>
    <div class="mb-4">
      <%= f.label :password, class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.password_field :password, class: "w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-100 focus:border-blue-500 transition outline-none" %>
    </div>
    <div class="mb-6">
      <%= f.label :password_confirmation, "Confirmation", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.password_field :password_confirmation, class: "w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-100 focus:border-blue-500 transition outline-none" %>
    </div>
    <%= f.submit "Update password", class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-4 rounded-xl shadow-sm hover:shadow transition cursor-pointer text-center" %>
  <% end %>
</div>