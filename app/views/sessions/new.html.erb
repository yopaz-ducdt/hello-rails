<% provide(:title, "Log in") %>
<div class="max-w-md mx-auto mt-10 bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
  <h1 class="text-3xl font-extrabold text-center text-gray-900 tracking-tight mb-8">
    Log in
  </h1>
  <%= form_with(url: login_path, scope: :session, local: true, class: "space-y-5") do |f| %>
    <div>
      <%= f.label :email, "Email", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.email_field :email, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-sm shadow-sm" %>
    </div>
    <div>
      <%= f.label :password, "Password", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.password_field :password, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-sm shadow-sm" %>
    </div>
    <div class="flex items-center">
      <%= f.check_box :remember_me, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded cursor-pointer" %>
      <%= f.label :remember_me, class: "ml-2 block text-sm font-medium text-gray-700 cursor-pointer select-none" %>
    </div>
    <div class="pt-2">
      <%= f.submit "Log in", class: "w-full py-2.5 px-4 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg shadow transition duration-150 ease-in-out text-center cursor-pointer" %>
    </div>
  <% end %>
  <p class="mt-6 text-center text-sm text-gray-600">
    New user? 
    <%= link_to "Sign up now!", signup_path, class: "text-blue-600 hover:underline font-medium" %>
  </p>
</div>